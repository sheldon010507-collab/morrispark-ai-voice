{
  "version": 2,
  "builds": [
    {
      "src": "api/**/*.py",
      "use": "@vercel/python"
    },
    {
      "src": "frontend/static/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/health",
      "dest": "/api/health.py"
    },
    {
      "src": "/embed.html",
      "headers": {
        "Content-Security-Policy": "frame-ancestors *"
      },
      "dest": "/frontend/static/embed.html"
    },
    {
      "src": "/(.*\\.(?:css|js|json|png|jpg|jpeg|gif|webp|svg|ico|txt|map))",
      "dest": "/frontend/static/$1"
    },
    {
      "src": "/(.*)",
      "headers": {
        "Content-Security-Policy": "frame-ancestors *"
      },
      "dest": "/frontend/static/index.html"
    }
  ]
}
