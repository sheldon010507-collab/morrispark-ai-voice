DEMO_PASSWORD=morris

# Leave mock for local UI/RAG/lead testing. Set to nvidia-ws when you have
# the Nemotron VoiceChat WebSocket endpoint for your Early Access account.
# Set to qwen-realtime for Alibaba Cloud Model Studio / DashScope Realtime.
VOICECHAT_BACKEND=mock

NVIDIA_API_KEY=
NVIDIA_VOICECHAT_WS_URL=
NVIDIA_VOICECHAT_FUNCTION_ID=

# Optional JSON string merged into the session.start message sent to NVIDIA.
# Example:
# NVIDIA_VOICECHAT_SESSION_JSON={"model":"nvidia/nemotron-voicechat","audio":{"input_format":"webm_opus"}}
NVIDIA_VOICECHAT_SESSION_JSON=

# Alibaba Cloud international Singapore realtime endpoint.
DASHSCOPE_API_KEY=
QWEN_REALTIME_ENDPOINT=wss://dashscope-intl.aliyuncs.com/api-ws/v1/realtime
QWEN_REALTIME_MODEL=qwen3.5-omni-plus-realtime
QWEN_REALTIME_VOICE=Cherry

HTTP_HOST=127.0.0.1
HTTP_PORT=5173
WS_HOST=127.0.0.1
WS_PORT=8001

# Set this for remote HTTPS demos, for example wss://your-ws-tunnel.example.com
PUBLIC_WS_URL=
